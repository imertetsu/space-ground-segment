# --- OS / editor cruft ---
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# --- Secrets / local env (never commit) ---
.env
.env.*
!.env.example
*.local
secrets/
*.pem
*.key

# --- Logs / temp ---
*.log
logs/
tmp/
.cache/

# --- Build / dependency output ---
dist/
build/
out/
coverage/

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# --- Node / web (viz, Epic 4) ---
node_modules/
.next/
.vite/

# --- Java / Yamcs (control, Epic 2) ---
target/
*.class
.gradle/
# Recorded CCSDS packet dumps (quickstart demo data, ~10MB) — Phase 1's simulator
# generates packets live; keep local, don't version.
*.ccsds

# --- Data / products (never commit downloaded EO data; only tiny labelled fixtures) ---
data/
*.nc
*.zip
!payload/fixtures/**
# viz/ ships small canned, labelled artifacts (real TLE + shared-catalogue snapshot)
# that the static app needs — track them despite the broad data/ rule above.
!viz/public/data/
!viz/public/data/**

# Claude Code files — kept locally, not published to the repo
CLAUDE.md
.claude/
