# Copy to `.env` and fill in. NEVER commit `.env` (it is gitignored).

# --- EUMETSAT Data Store (eumdac) — Epic 1 payload ingestion ---
# Create a free account at https://eumetsat.int, then copy your API
# Consumer Key / Secret from the EO Portal. Required before Phase 1 (ingestion).
EUMETSAT_CONSUMER_KEY=your-consumer-key
EUMETSAT_CONSUMER_SECRET=your-consumer-secret

# --- Shared catalogue (PostgreSQL) — Epic 3 onward ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sgs_catalogue
POSTGRES_USER=sgs
POSTGRES_PASSWORD=change-me

# --- Yamcs / simulator — Epic 2 (FOS) ---
# SIMULATOR_TM_UDP_PORT=10015
# YAMCS_HTTP_PORT=8090
